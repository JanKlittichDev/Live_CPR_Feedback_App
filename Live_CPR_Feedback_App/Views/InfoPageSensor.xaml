<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ViewModels="clr-namespace:Live_CPR_Feedback_App.ViewModels"
             x:Class="Live_CPR_Feedback_App.Views.InfoPageSensor"
             x:DataType="ViewModels:InfoSensorViewModel"
             Title="Acceleration-Sensor"
             Shell.TitleColor="White"
             Shell.ForegroundColor="White">

    <Grid RowDefinitions="*,*,Auto" Padding="24" RowSpacing="16">

        <!-- Normierte Werte -->
        <Border Grid.Row="0"
                BackgroundColor="#1A1A1A"
                Stroke="Gray"
                StrokeShape="RoundRectangle 16"
                Padding="20">
            <VerticalStackLayout Spacing="10">
                <Label Text="Normalized values"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center" />

                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0" Text="X" FontSize="16" TextColor="Gray" HorizontalTextAlignment="Center"/>
                    <Label Grid.Row="0" Grid.Column="1" Text="Y" FontSize="16" TextColor="Gray" HorizontalTextAlignment="Center"/>
                    <Label Grid.Row="0" Grid.Column="2" Text="Z" FontSize="16" TextColor="Gray" HorizontalTextAlignment="Center"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding X, StringFormat='{0:F2}'}" FontSize="24" TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding Y, StringFormat='{0:F2}'}" FontSize="24" TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Grid.Row="1" Grid.Column="2" Text="{Binding Z, StringFormat='{0:F2}'}" FontSize="24" TextColor="White" HorizontalTextAlignment="Center"/>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,4"/>

                <Label HorizontalTextAlignment="Center" FontSize="18" TextColor="White">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Total: " FontAttributes="Bold" />
                            <Span Text="{Binding Total, StringFormat='{0:F2}'}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </VerticalStackLayout>
        </Border>

        <!-- Werte in m/s^2 -->
        <Border Grid.Row="1"
                BackgroundColor="#1A1A1A"
                Stroke="Gray"
                StrokeShape="RoundRectangle 16"
                Padding="20">
            <VerticalStackLayout Spacing="10">
                <Label Text="Acceleration [m/s²]"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center" />

                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0" Text="X" FontSize="16" TextColor="Gray" HorizontalTextAlignment="Center"/>
                    <Label Grid.Row="0" Grid.Column="1" Text="Y" FontSize="16" TextColor="Gray" HorizontalTextAlignment="Center"/>
                    <Label Grid.Row="0" Grid.Column="2" Text="Z" FontSize="16" TextColor="Gray" HorizontalTextAlignment="Center"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding XCorrected, StringFormat='{0:F2}'}" FontSize="24" TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding YCorrected, StringFormat='{0:F2}'}" FontSize="24" TextColor="White" HorizontalTextAlignment="Center"/>
                    <Label Grid.Row="1" Grid.Column="2" Text="{Binding ZCorrected, StringFormat='{0:F2}'}" FontSize="24" TextColor="White" HorizontalTextAlignment="Center"/>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="Gray" Margin="0,4"/>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                    <Label Text="Total:" FontAttributes="Bold" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                    <Label Text="{Binding TotalCorrected, StringFormat='{0:F2}'}" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                    <Label Text="m/s²" FontSize="18" TextColor="White" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="16">
            <Button Grid.Column="0"
                    Text="Start"
                    Command="{Binding StartCommand}"
                    HorizontalOptions="Fill" />
            <Button Grid.Column="1"
                    Text="Stop"
                    Command="{Binding StopCommand}"
                    HorizontalOptions="Fill" />
        </Grid>

    </Grid>

</ContentPage>