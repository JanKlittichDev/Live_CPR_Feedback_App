<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ViewModels="clr-namespace:Live_CPR_Feedback_App.ViewModels"
             x:Class="Live_CPR_Feedback_App.Views.InstructionPerformCPRPage"
             x:DataType="ViewModels:InstructionPerformCPRViewModel"
             Title="Compression Instruction"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             Shell.TitleColor="White"
             Shell.ForegroundColor="White">


    <ScrollView x:Name="InstructionScrollView">
        <VerticalStackLayout Padding="10"
                             Spacing="8">


            <Button Text="Start Chest Compression!"
                    Command="{Binding StartCPRCommand}"
                    BackgroundColor="Red"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="62"
                    FontSize="22"
                    FontAttributes="Bold"
                    Rotation="180" />


            <Border BackgroundColor="White"
                    Stroke="Gray"
                    StrokeShape="RoundRectangle 18"
                    Padding="16"
                    Rotation="180">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Chest Compression Instruction"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="DarkBlue" />
                    <Label Text="• Place your hands on the smartphone as shown in the picture."
                           FontSize="16"
                           TextColor="Black" />
                    <Label Text="• Put one hand on top of the other and interlock your fingers."
                           FontSize="16"
                           TextColor="Black" />
                    <Label Text="• Keep your arms straight and use your upper body weight."
                           FontSize="16"
                           TextColor="Black" />
                    <Label Text="• Keep interruptions as short as possible."
                           FontSize="16"
                           TextColor="Black" />
                    <Label Text="• 5–6 cm deep and allow full chest recoil."
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Label Text="• 100–120 compressions/min (thinking of matching rhythms of popular songs like &quot;Stayin' Alive&quot; helps)."
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Label Text="• If trained: perform 2 rescue breaths after 30 chest compressions."
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="Black" />
                    <Image Source="instructionperformcprpage_image.png"
                           HeightRequest="500"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Border>


            <Border x:Name="WarningFrame"
                    BackgroundColor="White"
                    Stroke="Gray"
                    StrokeShape="RoundRectangle 16"
                    Padding="16"
                    Rotation="180">
                <VerticalStackLayout Spacing="10">
                    <Label Text="⚠️ Warning: This application is for educational purposes only and not for usage."
                           FontSize="18"
                           TextColor="Red"
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>


            <Button x:Name="BackButton"
                    Text="← Back"
                    Command="{Binding BackCommand}"
                    BackgroundColor="Purple"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="62"
                    FontSize="22"
                    FontAttributes="Bold"
                    Rotation="180" />


        </VerticalStackLayout>
    </ScrollView>


</ContentPage>